---
interface Props {
  title: string;
  subtitle: string;
  topIcon?: string;       // path to top-right icon; defaults to sun
  showTopIcon?: boolean;  // show top-right icon; default true
  showSunBl?: boolean;    // show bottom-left sun; default true
}

const {
  title,
  subtitle,
  topIcon = '/images/icons/SWF - Sun.png',
  showTopIcon = true,
  showSunBl = true,
} = Astro.props;
---

<section class="page-header">
  {showTopIcon && <img src={topIcon} alt="" class="header-sun" aria-hidden="true" />}
  {showSunBl && <img src="/images/icons/SWF - Sun.png" alt="" class="sun-bl" aria-hidden="true" />}
  <div class="container">
    <h1>{title}</h1>
    <p>{subtitle}</p>
  </div>
</section>
