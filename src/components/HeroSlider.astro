---
const slides = [
  { src: '/images/photos/image1.jpg', alt: 'Summer Willis Foundation community photo 1' },
  { src: '/images/photos/image2.jpg', alt: 'Summer Willis Foundation community photo 2' },
  { src: '/images/photos/image3.jpg', alt: 'Summer Willis Foundation community photo 3' },
  { src: '/images/photos/summer3.jpg', alt: 'Summer Willis Foundation community photo 4' },
];
---

<div class="slider" id="hero-slider">
  <div class="slides-track" id="slides-track">
    {slides.map((slide, i) => (
      <div class:list={['slide', { active: i === 0 }]} data-index={i}>
        <img src={slide.src} alt={slide.alt} />
      </div>
    ))}
  </div>

  <!-- Double wave transition -->
  <div class="slider-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 30" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,6 C120,6 240,30 360,30 C480,30 600,6 720,6 C840,6 960,30 1080,30 C1200,30 1320,6 1440,6 L1440,30 L0,30 Z" fill="rgba(0,144,157,0.85)"/>
      <path d="M0,30 C120,30 240,6 360,6 C480,6 600,30 720,30 C840,30 960,6 1080,6 C1200,6 1320,30 1440,30 L1440,30 L0,30 Z" fill="#006b7a"/>
    </svg>
  </div>

  <!-- Arrows -->
  <button class="arrow arrow-prev" id="arrow-prev" aria-label="Previous slide">&#8249;</button>
  <button class="arrow arrow-next" id="arrow-next" aria-label="Next slide">&#8250;</button>

  <!-- Dots -->
  <div class="dots">
    {slides.map((_, i) => (
      <button
        class:list={['dot', { active: i === 0 }]}
        data-dot={i}
        aria-label={`Go to slide ${i + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.slide'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function startTimer() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  document.getElementById('arrow-prev')!.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
  document.getElementById('arrow-next')!.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
  dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetTimer(); }));

  startTimer();
</script>

<style>
  .slider {
    position: relative;
    width: 100%;
    height: 780px;
    overflow: hidden;
    background: #000;
  }

  .slides-track {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .slider-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 10;
    line-height: 0;
    pointer-events: none;
  }

  .slider-wave svg {
    width: 100%;
    height: 30px;
    display: block;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .slide.active {
    opacity: 1;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    animation: kenburns-a 12s ease-in-out infinite alternate;
  }

  .slide:nth-child(1) img { object-position: center bottom; }
  .slide:nth-child(2) img { animation-name: kenburns-b; }
  .slide:nth-child(3) img { animation-name: kenburns-c; }
  .slide:nth-child(4) img { animation-name: kenburns-d; object-position: center bottom; }

  @keyframes kenburns-a {
    0%   { transform: scale(1.05) translate(0, 0); }
    100% { transform: scale(1.12) translate(-1.5%, 1%); }
  }

  @keyframes kenburns-b {
    0%   { transform: scale(1.12) translate(1%, 0); }
    100% { transform: scale(1.05) translate(-1%, 1%); }
  }

  @keyframes kenburns-c {
    0%   { transform: scale(1.05) translate(1%, 0.5%); }
    100% { transform: scale(1.12) translate(0, -1%); }
  }

  @keyframes kenburns-d {
    0%   { transform: scale(1.12) translate(-1%, -0.5%); }
    100% { transform: scale(1.05) translate(1%, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide img { animation: none; }
  }

  /* Arrows */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    transition: background 0.2s;
    z-index: 10;
  }

  .arrow:hover { background: rgba(255, 255, 255, 0.4); }

  .arrow-prev { left: 1.25rem; }
  .arrow-next { right: 1.25rem; }

  /* Dots */
  .dots {
    position: absolute;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid white;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active {
    background: white;
  }

  @media (max-width: 1024px) {
    .slider { height: 540px; }
  }

  @media (max-width: 768px) {
    .slider { height: 460px; }
    .arrow { width: 38px; height: 38px; font-size: 1.5rem; }
  }

  @media (max-width: 480px) {
    .slider { height: min(380px, 60vh); }
    .arrow { width: 34px; height: 34px; font-size: 1.25rem; }
  }
</style>
