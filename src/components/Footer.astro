---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/images/Logo/footer_image_2.jpeg" alt="Summer Willis Foundation" class="footer-logo" />
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Organization</h4>
        <a href="/about">About Us</a>
        <a href="/campaigns">Our Campaigns</a>
        <a href="/blog">Blog & News</a>
      </div>
      <div class="link-group">
        <h4>Get Involved</h4>
        <a href="/get-involved">Volunteer</a>
        <a href="/get-involved#donate">Donate</a>
        <a href="/contact">Partner With Us</a>
      </div>
      <div class="link-group">
        <h4>Connect</h4>
        <a href="/contact">Contact</a>
        <a href="https://www.instagram.com/summerwillisfoundation/?__d=1%2F" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="#">Facebook</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Summer Willis Foundation. All rights reserved. 501(c)(3) Non-Profit Organization.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-primary-dark);
    color: rgba(255,255,255,0.8);
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1.5rem;
    align-items: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo {
    width: 150px;
    height: auto;
    display: block;
    mix-blend-mode: screen;
  }

  .footer-brand p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin-top: 0.25rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .link-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link-group h4 {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }

  .link-group a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .link-group a:hover { color: var(--c-yellow); }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 1.25rem 1.5rem;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
