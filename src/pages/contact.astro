---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  { icon: null, label: 'Address', value: '1234 Community Way, Springfield, ST 12345', useLocationIcon: true },
  { icon: '📞', label: 'Phone', value: '(555) 234-5678', useLocationIcon: false },
  { icon: '📧', label: 'Email', value: 'hello@brightrootsorg.org', useLocationIcon: false },
  { icon: '🕐', label: 'Office Hours', value: 'Mon–Fri: 9am–5pm · Sat: 9am–1pm', useLocationIcon: false },
];
---

<Layout title="Contact Us" description="Get in touch with Summer Willis Foundation — we'd love to hear from you.">

  <section class="page-header">
    <img src="/images/icons/SWF - Sun.png" alt="" class="sun-bl" aria-hidden="true" />
    <img src="/images/icons/SWF - You Are Here.png" alt="" class="you-are-here-header" aria-hidden="true" />
    <div class="container">
      <h1>Contact Us</h1>
      <p>We'd love to hear from you. Reach out with questions, partnership ideas, or just to say hello.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">

      <!-- Contact Info -->
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <p class="info-intro">Whether you're looking for services, want to volunteer, or have questions — our team is here to help.</p>

        <div class="info-list">
          {contactInfo.map(item => (
            <div class="info-item">
              <div class="info-icon">
                {item.useLocationIcon
                  ? <img src="/images/icons/SWF - You Are Here.png" alt="Location" class="location-icon" />
                  : item.icon
                }
              </div>
              <div>
                <div class="info-label">{item.label}</div>
                <div class="info-value">{item.value}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="social-links">
          <h3>Follow Us</h3>
          <div class="social-row">
            <a href="#" class="social-btn">📘 Facebook</a>
            <a href="https://www.instagram.com/summerwillisfoundation/?__d=1%2F" target="_blank" rel="noopener noreferrer" class="social-btn">📸 Instagram</a>
            <a href="#" class="social-btn">🐦 Twitter</a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="form-box">
        <h2>Send a Message</h2>
        <form class="form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" placeholder="you@example.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject">
              <option value="">Select a topic...</option>
              <option>General Question</option>
              <option>Volunteer Inquiry</option>
              <option>Donation / Partnership</option>
              <option>Program / Services</option>
              <option>Media Inquiry</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" rows="5" placeholder="How can we help?" required></textarea>
          </div>
          <button type="submit" class="submit-btn">Send Message</button>
        </form>
      </div>

    </div>
  </section>

  <!-- Map placeholder -->
  <div class="map-placeholder">
    <span>🗺️ Map — 1234 Community Way, Springfield</span>
  </div>

</Layout>

<style>
  .page-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--c-primary-dark), var(--c-primary));
    color: white;
    padding: 4rem 0;
    text-align: center;
  }

  .you-are-here-header {
    position: absolute;
    top: -15px;
    right: -15px;
    width: 180px;
    height: auto;
    opacity: 0.12;
    pointer-events: none;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .page-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0 auto;
    max-width: 560px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info h2,
  .form-box h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .info-intro {
    color: #6b7280;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .info-icon { font-size: 1.25rem; flex-shrink: 0; line-height: 1; }

  .location-icon {
    width: 28px;
    height: auto;
    display: block;
  }

  .info-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }

  .info-value { font-size: 0.95rem; color: #374151; }

  .social-links h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .social-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .social-btn {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--c-blue-light);
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    color: #374151;
    background: var(--c-bg-blue);
    transition: border-color 0.15s, background 0.15s;
  }

  .social-btn:hover {
    border-color: var(--c-primary);
    background: var(--c-bg-teal);
    color: var(--c-primary);
  }

  /* Form */
  .form-box {
    background: var(--c-bg-teal);
    border: 1px solid var(--c-blue-light);
    border-radius: 16px;
    padding: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.6rem 0.85rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #111827;
    background: white;
    transition: border-color 0.15s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(0, 144, 157, 0.12);
  }

  .submit-btn {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    background: var(--c-primary);
    color: white;
    transition: background 0.15s, transform 0.1s;
  }

  .submit-btn:hover {
    background: var(--c-primary-dark);
    transform: translateY(-1px);
  }

  /* Map */
  .map-placeholder {
    height: 280px;
    background: var(--c-bg-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-blue);
    font-size: 1.1rem;
    border-top: 1px solid var(--c-blue-light);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
