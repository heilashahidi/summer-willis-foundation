---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import { HEX_TO_CLASS } from '../lib/constants';

const advisors = [
  {
    name: 'Kelly Joseph',
    role: 'Founder, La Sœur Fund',
    initials: 'KJ',
    color: '#00909d',
    photo: '/images/headshots/Kelly_Joseph.png',
    photoScale: 1.1,
    photoPosition: '30% 20%',
    bio: [
      'Kelly Shawn Joseph is a specialist in preventing and responding to violence against women and girls across humanitarian, development, and crisis-affected contexts, including Afghanistan, Bangladesh, Central African Republic, Iraq, Lebanon, Mali, Somalia, and Ukraine. Her work focuses on strengthening survivor-centered prevention and response systems in complex and politically constrained environments.',
      'She is the Founder of La Sœur Fund, a women\'s fund that directly resources grassroots women- and girl-led organizations responding to violence in emergencies through participatory grantmaking and trust-based, risk-aware approaches. In advisory roles, Kelly supports organizations to deepen technical rigor while remaining accountable to survivors, frontline practitioners, and feminist movements.',
    ],
  },
  {
    name: 'Kathryne Hemmings',
    role: 'Senior Counsel, Horn Williamson LLC',
    initials: 'KH',
    color: '#d4a000',
    photo: '/images/headshots/Kathryne.png',
    photoScale: 1.1,
    photoPosition: '65% 20%',
    bio: [
      'Kathryne Hemmings is a survivor, an advocate, and an attorney committed to ensuring that those who experience sexual violence are met with dignity, belief, and meaningful support. Her connection to this work began long before her legal career. As an undergraduate at Clemson University, she survived a sexual assault that reshaped her life and her understanding of what it means to navigate trauma in environments that often feel unprepared, or unwilling, to help.',
      'That experience fuels her dedication to ensuring no survivor feels alone in the aftermath of harm. In her legal career, Kathryne has represented students who were assaulted at their universities, supporting them as they faced complex institutional processes and deeply personal challenges.',
      'Beyond litigation, Kathryne is committed to community education, outreach, and opening pathways to healing, especially for those who feel silenced by stigma or discouraged by systems that have failed them.',
      'Today, Kathryne serves as Senior Counsel at Horn Williamson, LLC in Philadelphia, where she represents homeowners and community members in complex civil matters.',
    ],
  },
  {
    name: 'Sophia-Rose Centurioni',
    role: 'Dancer, Advocate & Survivor',
    initials: 'SC',
    color: '#ef3f6b',
    photo: '/images/headshots/Sophia-Rose.png',
    photoScale: 1.2,
    photoPosition: '30% 30%',
    bio: [
      'Sophia-Rose is a dancer, advocate, and survivor who uses her story to help others feel safe, seen, and supported. She was sexually assaulted at 16, a trauma that brought fear, shame, and silence. Through therapy, education, and steady healing, she reclaimed her voice and learned that adversity does not define her.',
      'Today, she speaks openly so no young person feels alone in their recovery. Through her work with R.I.S.E. (Resilience, Inspiration, Support, Empowerment), she teaches teens about safety, boundaries, healthy relationships, and the power of healing.',
    ],
  },
  {
    name: 'Paulina Pizarro',
    role: 'Nonprofit Management · 25+ Years',
    initials: 'PP',
    color: '#6e98b9',
    photo: '/images/headshots/Paulina.jpg',
    photoScale: 1.2,
    photoPosition: '0% 60%',
    bio: [
      'Paulina has over 25 years of experience in nonprofit management, working and volunteering in arts management, education, and equity-based organizations. She has served on various nonprofit boards throughout her career.',
      'Originally from Chile · B.A. Economics, Texas A&M University',
    ],
  },
  {
    name: 'Ashley Brooks',
    role: 'Senior Policy Advisor, TAASA',
    initials: 'AB',
    color: '#006b7a',
    bio: [
      'Ashley Brooks currently serves as the Senior Policy Advisor for the Texas Association Against Sexual Assault (TAASA). She brings over 20 years of experience in public service to the Summer Willis Foundation Advisory Board.',
      'Alumna, University of Texas at Austin',
    ],
  },
  {
    name: 'Gabriella Taylor, M.A.',
    role: 'Founder, Extraordinary Woman',
    initials: 'GT',
    color: '#d4a000',
    photo: '/images/headshots/Gabriella.jpg',
    photoScale: 1.1,
    bio: [
      'Founder of Extraordinary Woman and pioneer of the Neuroscience of Feminine Power, Gabriella changes women from the inside out, mentoring women of influence and means to discover the authentic, courageous, loving voice within and use it for good.',
      'Gabriella Taylor, M.A. is the founder of Extraordinary Woman and a pioneer of the Neuroscience of Feminine Power, devoting her life to one essential truth: the most powerful thing a woman can do is become fully herself.',
      'Trusted by Presidential appointees, Grammy-winning artists, and philanthropic leaders, she draws from her own journey of transformation and nearly thirty years in private practice, bridging neuroscience, psyche, and soul to mentor women of influence and means to discover the authentic, courageous, loving voice within and use it for good.',
      'Her work guides them toward a new model of what it means to lead, love, and live in the 21st century. Because the world changes when women do. Based in Montecito, CA, she brings both her life\'s work and her personal understanding as a survivor to her role as Executive Producer of A Letter to My Younger Self.',
    ],
  },
  { name: 'Briana Ferringo', role: 'CEO of Matriarch', initials: 'BF', color: '#f37f8e', photo: '/images/headshots/Briana.png', photoScale: 1.3, photoPosition: '50% 30%', bio: ['Briana Ferringo is the CEO of Matriarch, an Impact Marketing Firm specializing in Women\'s Health. She is also the Co-founder of Changemaker Chats, a global women\'s leadership platform that connects and equips emerging female leaders through honest, off-the-record conversations with some of the world\'s most influential women.', 'She is a strategic communications and brand leader passionate about building communities and companies that power positive change. With a background in public health and communications, Briana spent her career translating complex ideas into stories that move people to act.', 'As one of the founding leaders of McCann Global Health, and its former President, she worked with governments, NGOs, and global brands to design campaigns that drove awareness, trust, and behavior change on issues that impact lives around the world. She brings a decade of experience in Public Health and Communications to the SWF Board.'] },
  { name: 'Emily Carter', role: 'Founding Member of Matriarch', initials: 'EC', color: '#6e98b9', photo: '/images/headshots/Emily.jpeg', photoPosition: '40% 50%', bio: ['Emily Carter is an experienced marketing and business leader with a decade of experience launching and growing health products and companies. She is a founding member of Matriarch.'] },
  { name: 'Drew Woodley', role: 'Head of Partnerships, Tixr Brands', initials: 'DW', color: '#00909d', photo: '/images/headshots/Drew Woodley.png', photoScale: 1.1, photoPosition: '70% 60%', bio: ['Drew Woodley is a committed advocate who has spent his career bringing unique, impactful and creative experiences to life. During his 18 years in the live events industry, he has helped launch and scale global events and experiences like Electric Run, Tomorrowworld, RiSE Festival, and the #LoveWins campaign, often directly in support of non-profit organizations. He met Summer Willis while she was training to run her first marathon and is proud to be a member of the Summer Willis Foundation Board, helping to raise funding and awareness through brand partnerships and marketing campaigns. Drew currently serves as Head of Partnerships for Tixr Brands and is based in South Lake Tahoe.'] },
  { name: 'Dini Von Mueffling', role: 'Founder of DVMC', initials: 'DV', color: '#d4a000', photo: '/images/headshots/Dini.png', photoScale: 1.25, photoPosition: '50% 75%', bio: ['Dini founded DVMC in 2015. Her public relations work is taught in universities, has been inducted into the Platinum PR Hall of Fame, and she has been recognized as one of the Top Women in PR by PR News.'] },
  { name: 'Will Rivera', role: 'Nonprofit Leader & Digital Safety Advocate', initials: 'WR', color: '#ef3f6b', photo: '/images/headshots/Will.png', photoScale: 1.2, photoPosition: '90% 50%', bio: ['Will Rivera began his career as a Victim Specialist at Opportunities for Otsego, a human services agency, before working his way up to Executive Director at the New York State Coalition Against Sexual Assault, where he oversaw 70 statewide programs serving hundreds of thousands of survivors.', 'Will is a Trust & Safety professional dedicated to digital safety who has directly supported thousands of survivors of technology-facilitated violence, sexual violence, domestic violence, and other violent crimes. His experience spans nonprofit management, grant writing, public speaking, and policy advocacy, helping secure millions in state funding and playing a key role in passing legislation to support survivors.', 'Will\'s drive comes from his own story. Growing up in the NYC projects, he faced many of the same challenges he now dedicates his career to addressing.'] },
  { name: 'Valeria Angyal', role: 'VP of Philanthropy, Alpha Chi Omega', initials: 'VA', color: '#6e98b9', photo: '/images/headshots/Valeria.png', photoScale: 1.1, photoPosition: '60% 65%', bio: ['Valeria Angyal is the VP of Philanthropy for the Alpha Chi Omega Chapter at the University of Texas at Austin. She assists with driving student-level engagement and fostering relationships with panhellenic chapters across US Universities.'] },
];

---

<Layout title="About Us" description="Learn about Summer Willis Foundation: our story, mission, and the team dedicated to survivor advocacy and systemic change.">

  <PageHeader
    title="About Summer Willis Foundation"
    subtitle="A survivor-centered organization built on advocacy, community, and lasting change."
  />

  <!-- Tagline Banner -->
  <section class="tagline-section">
    <div class="container">
      <p class="tagline">Through trauma-informed advocacy, bipartisan collaboration, and transformative storytelling, we create spaces where survivors are empowered to share their experiences and drive systemic change.</p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-text">
        <h2 class="section-title">Our Story</h2>
        <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
        <p>Our founder, Summer Willis, is a survivor of sexual violence. In the wake of her assault, she experienced firsthand the systemic failures, silence, and shame that often define the survivor experience. She began running as a bold act of reclamation. This personal challenge grew into <a href="https://www.glamour.co.za/lifestyle/motivation-monday-summer-willis-on-resilience-running-29-marathons-and-turning-pain-into-purpose-ee96ef85-5c85-424e-8968-77d37c3cbf5a" target="_blank" rel="noopener noreferrer" style="color: #00909d;"><strong>'Project 29'</strong></a>, a commitment to run 29 marathons as a testament to her own resilience. She met survivors around the world, each with different lives yet she observed the same pattern. She realized Sexual violence thrives on shame, silence, and laws that haven't kept up with reality. Eventually, Project 29 grew into the Summer Willis Foundation. SWF was established to combat the root causes of sexual violence in innovative and community-driven ways to make a lasting impact.</p>
      </div>
      <div class="story-image">
        <div class="video-frame">
          <video
            class="story-video"
            controls
            preload="metadata"
            id="story-video"
          >
            <source src="/images/videos/summer_vid.mov" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- Story + Values Combined -->
  <section class="section story-values-section">
    <div class="container story-values-grid">

      <!-- Left: Extended Story -->
      <div class="story-extended">
        <div class="section-eyebrow">All About Our Story</div>
        <h2 class="section-title">Running was only the start.</h2>
        <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
        <p>Summer found her true, renewed strength not just in the miles, but in community, in the power of telling her story without shame , and in a fierce new purpose: creating tangible change so that what happened to her wouldn't happen to others. She realized she had a choice: accept the narrative of 'victim,' or rewrite it. She chose to rewrite it. That single run transformed into a public mission. What started as 'Project 29' became a movement. Summer founded the Summer Willis Foundation to ensure that no survivor ever feels alone and that every survivor has the tools to find their own power, whether on the running path, in their community, or in creating systemic change.</p>
      </div>

      <!-- Right: Card Stack -->
      <div class="card-stack-wrap">
        <p class="values-label">Mission &amp; Values</p>
        <p class="values-hint">Click to flip through</p>
        <div class="card-stack" id="values-stack">
          <div class="stack-card card-teal">
            <div class="stack-icon">🎯</div>
            <h3>Our Mission</h3>
            <p>Through our commitment to advocacy, community, and resource provision, the Summer Willis Foundation exists to reframe the narrative around sexual violence, empower survivors to reclaim their stories, and create lasting systemic change that prevents future harm.</p>
          </div>
          <div class="stack-card card-yellow">
            <div class="stack-icon">💛</div>
            <h3>Believe Survivors</h3>
            <p>We center survivor voices in everything we do, leading with compassion, trust, and unconditional support.</p>
          </div>
          <div class="stack-card card-pink">
            <div class="stack-icon">🤝</div>
            <h3>Community</h3>
            <p>Healing happens in community. We build brave, connected spaces where survivors are never alone.</p>
          </div>
          <div class="stack-card card-blue">
            <div class="stack-icon">📣</div>
            <h3>Systemic Change</h3>
            <p>We don't just respond to harm; we work to dismantle the systems and cultures that allow it to persist.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Tenets -->
  <section class="section tenets-section">
    <img src="/images/icons/SWF - You Are Here.png" alt="" class="decor-icon decor-br" aria-hidden="true" />
    <div class="container">
      <h2 class="section-title">How We Create Change</h2>
      <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
      <p class="section-subtitle">Three core pillars drive everything we do, from the individual survivor to systems of power.</p>
      <div class="tenets-grid">

        <div class="tenet-card tenet-teal">
          <div class="tenet-number">01</div>
          <h3>Combatting Stigma and Shame</h3>
          <p>We're combatting shame and stigma by focusing on resilience, community, and strength. SWF understands that community and collective action can be transformative in ending stigma and empowering individuals to be their own change-makers. With this, we build a movement to end sexual violence. </p>
        </div>

        <div class="tenet-card tenet-yellow">
          <div class="tenet-number">02</div>
          <h3>Building Survivor-Led Communities</h3>
          <p>We foster local, national and global safe spaces where survivors and allies can connect, heal, and create lasting change together, through our Denim Race Series, speaking engagements, upcoming Resource Map and Advocacy Bootcamp projects, and more.</p>
        </div>

        <div class="tenet-card tenet-pink">
          <div class="tenet-number">03</div>
          <h3>Fighting for Policy Reform</h3>
          <p>We work with legislators across party lines at the highest levels of government, both federally and at the state level,  to push for stronger protections and accountability for survivors.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Meet Our Team</h2>
      <p class="section-subtitle">Dedicated advocates committed to survivors and systemic change every day.</p>

      <!-- Featured: Summer Willis -->
      <div class="founder-card founder-card--teal">
        <div class="founder-avatar founder-avatar--teal"><img src="/images/headshots/summer-willis.png" alt="Summer Willis" class="founder-avatar-photo" style="object-position: 100% top;" /></div>
        <div class="founder-info">
          <div class="founder-roles">
            <span class="founder-badge">Board President</span>
            <span class="founder-badge">Founder & Executive Director</span>
          </div>
          <h3>Summer Willis</h3>
          <p>Summer Willis is the Founder, Executive Director, and Board President of The Summer Willis Foundation. A Mom and Wife, her commitment to public service includes prior roles as a Teach for America educator and a Peace Corps Volunteer. Leveraging her personal journey, she became the namesake of the <strong>Summer Willis Act in Texas</strong>, which redefined consent law. She is an endurance athlete who sometimes takes on extreme challenges, such as running 29 marathons in a single year, to raise awareness and fund survivor resources.</p>
        </div>
      </div>

      <!-- Featured: Katiana Soenen -->
      <div class="founder-card founder-card--yellow">
        <div class="founder-avatar founder-avatar--yellow"><img src="/images/headshots/Katiana.png" alt="Katiana Soenen" class="founder-avatar-photo" style="transform: scale(1.1); transform-origin: center top;" /></div>
        <div class="founder-info">
          <div class="founder-roles">
            <span class="founder-badge">Board Vice President</span>
            <span class="founder-badge">Chief Development Officer</span>
          </div>
          <h3>Katiana Soenen</h3>
          <p>Katiana is the Board Vice President and Chief Development Officer at the Summer Willis Foundation, where she leads national awareness campaigns, fundraising initiatives, and organizational expansion.</p>
          <p style="margin-top: 0.75rem;">After being sexually assaulted during her first year of college, Katiana found strength in advocacy. Her early activism began with serving as a named plaintiff in a <strong>Title IX compliance case</strong>, pressing for stronger campus-safety systems and institutional accountability. Before joining SWF, she focused on grassroots efforts to expand resources for college survivors as well as reproductive rights advocacy in Texas and Tennessee.</p>
          <p style="margin-top: 0.75rem;">Alongside founder Summer Willis, Katiana now drives SWF's development pipeline, donor partnerships, multi-state growth, and high-impact national campaigns, including the forthcoming Denim Runs series, a national resource map for survivors, and the <a href="https://donorbox.org/a-letter-to-my-younger-self" target="_blank" rel="noopener">"Letter to My Younger Self" film</a>. She is dedicated to building innovative and sustainable infrastructure, amplifying survivor voices, and advancing meaningful policy change.</p>
          <p style="margin-top: 0.75rem; color: var(--c-text-secondary); font-size: 0.9rem;">Born and raised in Texas · B.A. Political Science & Public Health, Vanderbilt University · Certified Yoga Instructor</p>
        </div>
      </div>

      <!-- Featured: Samantha McCoy -->
      <div class="founder-card founder-card--pink">
        <div class="founder-avatar founder-avatar--pink"><img src="/images/headshots/Samantha.png" alt="Samantha McCoy" class="founder-avatar-photo" style="transform: scale(1.4); transform-origin: center top; object-position: center 55%;" /></div>
        <div class="founder-info">
          <div class="founder-roles">
            <span class="founder-badge">Board Secretary</span>
            <span class="founder-badge">VP for Public Policy</span>
          </div>
          <h3>Samantha McCoy</h3>
          <p>Samantha McCoy is an award-winning appellate attorney, public speaker, activist, and licensed master social worker. Following a sexually violent crime, Samantha dedicated her career to ensuring all gaps within the judicial system are finally closed and all survivors of sexual violence are treated in a dignified and trauma-informed manner.</p>
          <p style="margin-top: 0.75rem;">Samantha has successfully lobbied for several laws in five states, the <strong>federal TAKE IT DOWN Act</strong>, and a <strong>United Nations Resolution</strong>, all of which strengthened the rights and protections for survivors.</p>
          <p style="margin-top: 0.75rem; color: var(--c-text-secondary); font-size: 0.9rem;">M.S.W. & Certificate of Advanced Study in Trauma-Informed Practice, Syracuse University · J.D. <em>summa cum laude</em>, St. Mary's University School of Law</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Advisory Board -->
  <section class="section advisory-section">
    <img src="/images/icons/SWF - Sun.png" alt="" class="decor-icon decor-tr" aria-hidden="true" />
    <div class="container">
      <h2 class="section-title">Advisory Board</h2>
      <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
      <p class="section-subtitle">Experts, survivors, and advocates who guide our work with wisdom, lived experience, and specialized expertise.</p>

      <div class="advisory-grid grid-3">
        {advisors.map((a, i) => (
          <button class={`advisory-card card-${HEX_TO_CLASS[a.color] ?? 'teal'}`} data-index={i} aria-label={`Learn more about ${a.name}`}>
            <div class={`advisory-avatar av-${HEX_TO_CLASS[a.color] ?? 'teal'}`}>{a.photo ? <img src={a.photo} alt={a.name} class="advisory-avatar-photo" style={[a.photoPosition ? `object-position: ${a.photoPosition}` : '', a.photoScale ? `transform: scale(${a.photoScale}); transform-origin: ${a.photoPosition ?? '50% 50%'}` : ''].filter(Boolean).join('; ') || undefined} /> : a.initials}</div>
            <h3>{a.name}</h3>
            <span class="advisory-role">{a.role}</span>
            {a.bio.length > 0 && <span class="advisory-more">Learn more →</span>}
          </button>
        ))}
      </div>

      <!-- Modal -->
      <div class="adv-modal-backdrop" id="adv-modal" aria-modal="true" role="dialog" hidden>
        <div class="adv-modal-box">
          <button class="adv-modal-close" id="adv-modal-close" aria-label="Close">✕</button>
          <div class="adv-modal-header">
            <div class="adv-modal-avatar" id="adv-modal-avatar"></div>
            <div>
              <h3 id="adv-modal-name"></h3>
              <span id="adv-modal-role"></span>
            </div>
          </div>
          <div class="adv-modal-bio" id="adv-modal-bio"></div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Stand with survivors."
    body="Advocates, allies, and donors make our work possible."
    buttonText="Get Involved"
    buttonHref="/get-involved"
  />

</Layout>

<style>
  .tagline-section {
    background: var(--c-bg-yellow);
    border-bottom: 2px solid var(--c-yellow);
    padding: 2.5rem 0;
    text-align: center;
  }

  .tagline {
    max-width: 760px;
    margin: 0 auto;
    font-size: 1.15rem;
    line-height: 1.75;
    color: #374151;
    font-style: italic;
  }

  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary);
    margin-bottom: 0.4rem;
  }

  /* Combined Story + Values */
  .story-values-section { background: #f9fafb; }

  .story-values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .story-extended p {
    color: #4b5563;
    line-height: 1.75;
    margin: 0;
    font-size: 1rem;
  }

  /* Values Flip Cards */
  .values-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary);
    margin: 0 0 0.25rem;
  }

  .values-hint {
    font-size: 0.8rem;
    color: #9ca3af;
    margin: 0 0 1rem;
  }

  /* Card Stack */
  .card-stack-wrap { }

  .card-stack {
    position: relative;
    height: 280px;
    perspective: 1000px;
    cursor: pointer;
    margin-bottom: 1rem;
  }

  .stack-card {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    will-change: transform, box-shadow;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    will-change: transform;
  }

  .stack-card h3 {
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0;
    color: #111827;
  }

  .stack-card p {
    font-size: 0.95rem;
    font-weight: 500;
    color: #374151;
    line-height: 1.65;
    margin: 0;
  }

  .stack-icon { font-size: 2rem; }

  .stack-card.card-teal   { background: var(--c-bg-teal);   border: 2px solid rgba(0,144,157,0.25);   border-top: 2px solid rgba(0,144,157,0.25); }
  .stack-card.card-yellow { background: var(--c-bg-yellow);  border: 2px solid rgba(255,198,11,0.35);  border-top: 2px solid rgba(255,198,11,0.35); }
  .stack-card.card-pink   { background: var(--c-bg-pink);    border: 2px solid rgba(239,63,107,0.25);  border-top: 2px solid rgba(239,63,107,0.25); }
  .stack-card.card-blue   { background: var(--c-bg-blue);    border: 2px solid rgba(110,152,185,0.25); border-top: 2px solid rgba(110,152,185,0.25); }

  .story-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .story-text p {
    color: #4b5563;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .video-frame {
    position: relative;
    border-radius: 20px;
    padding: 8px;
    background: white;
    border: 3px solid var(--c-primary);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12), 6px 6px 0 var(--c-yellow);
  }

  .story-video {
    width: 100%;
    border-radius: 14px;
    display: block;
  }


  /* Tenets */
  .tenets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .tenet-card {
    border-radius: 16px;
    padding: 2rem;
    border-top: 4px solid transparent;
  }

  .tenet-teal { background: var(--c-bg-teal); border-top-color: var(--c-primary); }
  .tenet-yellow { background: var(--c-bg-yellow); border-top-color: var(--c-yellow); }
  .tenet-pink { background: var(--c-bg-pink); border-top-color: var(--c-pink-dark); }

  .tenet-number {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.75rem;
    font-family: 'TAYBirdie', system-ui, sans-serif;
  }

  .tenet-teal .tenet-number { color: var(--c-primary); }
  .tenet-yellow .tenet-number { color: var(--c-primary-dark); }
  .tenet-pink .tenet-number { color: var(--c-pink-dark); }

  .tenet-card h3 {
