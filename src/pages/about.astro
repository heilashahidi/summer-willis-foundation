<script define:vars={{ advisors }} is:inline>
  // Rewind video to start when it ends (without autoplaying)
  const video = document.getElementById('story-video');
  video?.addEventListener('ended', () => { video.currentTime = 0; });

  const modal = document.getElementById('adv-modal');
  const modalAvatar = document.getElementById('adv-modal-avatar');
  const modalName = document.getElementById('adv-modal-name');
  const modalRole = document.getElementById('adv-modal-role');
  const modalBio = document.getElementById('adv-modal-bio');
  const modalClose = document.getElementById('adv-modal-close');

  function openModal(index) {
    const a = advisors[index];
    if (!a || a.bio.length === 0) return;
    if (a.photo) {
      const scale = a.photoScale ?? 1.6;
      const pos = a.photoPosition ?? '30% top';
      modalAvatar.innerHTML = `<img src="${a.photo}" alt="${a.name}" class="adv-modal-avatar-photo" style="transform: scale(${scale}); transform-origin: ${pos}; object-position: ${pos};" />`;
      modalAvatar.style.background = 'transparent';
    } else {
      modalAvatar.textContent = a.initials;
      modalAvatar.style.background = a.color;
    }
    modalName.textContent = a.name;
    modalRole.textContent = a.role;
    modalBio.innerHTML = a.bio.map(p => `<p>${p}</p>`).join('');
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.advisory-card').forEach(card => {
    card.addEventListener('click', () => {
      const index = parseInt(card.dataset.index || '0');
      openModal(index);
    });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Card stack
  const stack = document.getElementById('values-stack');
  if (stack) {
    const cards = Array.from(stack.querySelectorAll('.stack-card'));
    let order = cards.map((_, i) => i);
    let animating = false;

    // Stack positions: [top → bottom]
    const positions = [
      { z: 4, rotate: '0deg',  tx: '0px',   ty: '0px' },
      { z: 3, rotate: '3deg',  tx: '8px',   ty: '8px' },
      { z: 2, rotate: '-2deg', tx: '-6px',  ty: '14px' },
      { z: 1, rotate: '5deg',  tx: '14px',  ty: '18px' },
    ];

    function place(card, pos, animate, delay = 0) {
      const p = positions[Math.min(pos, positions.length - 1)];
      card.style.transition = animate
        ? `transform 500ms cubic-bezier(0.34, 1.2, 0.64, 1) ${delay}ms, box-shadow 500ms ease ${delay}ms`
        : 'none';
      card.style.zIndex = String(p.z);
      card.style.transform = `rotate(${p.rotate}) translate(${p.tx}, ${p.ty})`;
      card.style.boxShadow = '';
    }

    function next() {
      if (animating) return;
      animating = true;

      const topIdx = order[0];
      const topCard = cards[topIdx];

      // Phase 1 — lift up (150ms)
      topCard.style.zIndex = '10';
      topCard.style.transition = 'transform 150ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 150ms ease';
      topCard.style.transform = 'rotate(-2deg) translateY(-16px) scale(1.04)';
      topCard.style.boxShadow = '0 20px 40px rgba(0,0,0,0.18)';

      setTimeout(() => {
        // Phase 2 — sweep right, clear of the deck (380ms)
        topCard.style.transition = 'transform 380ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 280ms ease';
        topCard.style.transform = 'rotate(6deg) translateX(115%) translateY(10%) scale(0.92)';
        topCard.style.boxShadow = '0 8px 24px rgba(0,0,0,0.10)';

        // Other cards rise simultaneously
        order.slice(1).forEach((cardIdx, i) => {
          place(cards[cardIdx], i, true, i * 30);
        });

        setTimeout(() => {
          // Card is fully to the side — safe to drop z-index, no overlap
          order = [...order.slice(1), topIdx];
          const backPos = positions[positions.length - 1];
          topCard.style.zIndex = String(backPos.z);

          // Phase 3 — slide INTO the back of the deck (300ms)
          topCard.style.transition = 'transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 300ms ease';
          topCard.style.transform = `rotate(${backPos.rotate}) translate(${backPos.tx}, ${backPos.ty})`;
          topCard.style.boxShadow = '';

          setTimeout(() => { animating = false; }, 320);
        }, 390);
      }, 150);
    }

    // Set initial positions
    order.forEach((cardIdx, pos) => place(cards[cardIdx], pos, false));
    stack.addEventListener('click', next);

    // Cursor tilt on top card only
    stack.addEventListener('mousemove', (e) => {
      if (animating) return;
      const topCard = cards[order[0]];
      const rect = stack.getBoundingClientRect();
      const rx = (((e.clientY - rect.top) - rect.height / 2) / (rect.height / 2)) * -8;
      const ry = (((e.clientX - rect.left) - rect.width / 2) / (rect.width / 2)) * 8;
      topCard.style.transition = 'transform 0.1s ease';
      topCard.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;
    });

    stack.addEventListener('mouseleave', () => {
      if (animating) return;
      const topCard = cards[order[0]];
      topCard.style.transition = 'transform 0.4s ease';
      const p = positions[0];
      topCard.style.transform = `rotate(${p.rotate}) translate(${p.tx}, ${p.ty})`;
    });
  }
</script>
