---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';


---

<Layout title="Get Involved" description="Volunteer or donate to Summer Willis Foundation and help build a stronger community.">

  <PageHeader
    title="Get Involved"
    subtitle="Your time, voice, and generosity help survivors heal and communities change."
    showTopIcon={false}
  />

  <!-- Donate -->
  <section id="donate" class="section donate-section">
    <img src="/images/icons/SWF - You Are Here.png" alt="" class="decor-icon decor-tr" aria-hidden="true" />
    <div class="container">
      <div class="donate-intro">
        <h2 class="donate-intro-title">Donate Today</h2>
        <p class="donate-intro-sub">Your support is the lifeline that fuels the Summer Willis Foundation.<br />Every stride, every run, every story matters, and none of it is possible without you.</p>
      </div>
    </div>
    <div class="container donate-inner">
      <div class="donate-text">
        <h2 class="section-title">Make a Donation</h2>
        <p class="section-subtitle">Every dollar goes directly to programs that support survivors and drive systemic change. Summer Willis Foundation is a 501(c)(3) organization, so your gift is tax-deductible.</p>
        <ul class="impact-list">
          <li>💛 <strong>$25</strong> provides educational resources to one survivor</li>
          <li>🤝 <strong>$100</strong> helps fund a healing circle session</li>
          <li>📣 <strong>$250</strong> supports a community awareness campaign</li>
          <li>🌟 <strong>$1,000</strong> sponsors a full program cycle for survivors</li>
        </ul>
      </div>
      <div class="donate-box">
        <h3>Make a Difference Today</h3>
        <p class="donate-box-sub">Safe, secure, and tax-deductible. Every dollar goes directly to survivors.</p>
        <givebutter-widget id="j2o5aL"></givebutter-widget>
        <p class="donate-note">🔒 Secure checkout. 100% goes to programs.</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section contact-section">
    <div class="container contact-grid">

      <div class="contact-info">
        <h2>Get in Touch</h2>
        <p class="info-intro">Whether you're looking for services, want to partner, or have questions, our team is here to help.</p>

        <div class="info-list">
          <div class="info-item">
            <div class="info-icon"><img src="/images/icons/SWF - You Are Here.png" alt="Location" class="location-icon" /></div>
            <div>
              <div class="info-label">Address</div>
              <div class="info-value">
                <div>Strength Through Strides</div>
                <div>PO Box 26431</div>
                <div>Austin, TX 78755</div>
              </div>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">📋</div>
            <div>
              <div class="info-label">EIN</div>
              <div class="info-value">93-3007343</div>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">📧</div>
            <div>
              <div class="info-label">Email</div>
              <div class="info-value">info@strengththroughstrides.org</div>
            </div>
          </div>
        </div>

        <div class="social-links">
          <h3>Follow Us</h3>
          <div class="social-row">
            <a href="https://www.facebook.com/profile.php?id=100093688899030" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--facebook" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
            <a href="https://www.instagram.com/summerwillisfoundation/?__d=1%2F" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--instagram" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              Instagram
            </a>
            <a href="https://www.linkedin.com/company/summer-willis-foundation/" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--linkedin" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="form-box">
        <h2>Send a Message</h2>
        <form class="form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" placeholder="you@example.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject">
              <option value="">Select a topic...</option>
              <option>General Question</option>
              <option>Volunteer Inquiry</option>
              <option>Donation / Partnership</option>
              <option>Program / Services</option>
              <option>Media Inquiry</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" rows="5" placeholder="How can we help?" required></textarea>
          </div>
          <button type="submit" class="submit-btn">Send Message</button>
        </form>
      </div>

    </div>
  </section>

</Layout>

<style>
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .role-card {
    display: flex;
    gap: 1rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .role-icon { font-size: 2rem; flex-shrink: 0; }

  .role-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.2rem;
  }

  .commitment {
    display: inline-block;
    background: var(--c-bg-teal);
    color: var(--c-primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    margin-bottom: 0.5rem;
  }

  .role-content p {
    font-size: 0.9rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .volunteer-form-box {
    background: var(--c-bg-teal);
    border: 1px solid var(--c-blue-light);
    border-radius: 16px;
    padding: 2rem;
    max-width: 680px;
  }

  .volunteer-form-box h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  /* Donate */
  .donate-section { position: relative; overflow: hidden; background: var(--c-bg-yellow); scroll-margin-top: 80px; }
  #volunteer { scroll-margin-top: 80px; }

  .donate-intro {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 3rem;
  }

  .donate-intro-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.75rem;
  }

  .donate-intro-sub {
    font-size: 1.15rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .donate-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .impact-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .impact-list li {
    font-size: 0.95rem;
    color: #374151;
  }

  .donate-box {
    background: white;
    border: 1px solid var(--c-yellow-light);
    border-radius: 16px;
    padding: 2rem;
    position: sticky;
    top: 100px;
    text-align: center;
    max-height: 680px;
    overflow-y: auto;
  }

  .donate-box h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0;
    color: #111827;
  }

  .donate-box-sub {
    font-size: 0.95rem;
    color: var(--c-text-secondary);
    line-height: 1.6;
    margin: 0;
  }


  .amount-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .amount-btn {
    padding: 0.6rem;
    border: 2px solid var(--c-yellow);
    background: var(--c-bg-yellow);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    font-family: inherit;
    color: #111827;
  }

  .amount-btn:hover {
    border-color: var(--c-yellow);
    background: var(--c-yellow);
  }

  .frequency-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .donate-btn {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    background: var(--c-pink-dark);
    color: white;
    transition: background 0.15s, transform 0.1s;
  }

  .donate-btn:hover {
    background: var(--c-pink);
    transform: translateY(-1px);
  }

  .donate-note {
    font-size: 0.8rem;
    color: #9ca3af;
    text-align: center;
    margin: 0;
  }

  /* Contact section */
  .contact-section { scroll-margin-top: 80px; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info h2,
  .form-box h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .info-intro {
    color: var(--c-text-secondary);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .info-icon { font-size: 1.25rem; flex-shrink: 0; line-height: 1; }

  .location-icon { width: 28px; height: auto; display: block; }

  .info-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }

  .info-value { font-size: 0.95rem; color: #374151; }

  .social-links h3 { font-size: 0.95rem; font-weight: 600; margin: 0 0 0.75rem; }
  .social-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--c-blue-light);
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    background: var(--c-bg-blue);
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .social-btn:hover { border-color: var(--c-primary); background: var(--c-bg-teal); color: var(--c-primary); }
  .social-btn--facebook:hover { background: #e7f0ff; border-color: #1877f2; color: #1877f2; }
  .social-btn--instagram:hover { background: #fdf0f8; border-color: #e1306c; color: #e1306c; }
  .social-btn--linkedin:hover { background: #e8f3fa; border-color: #0a66c2; color: #0a66c2; }

  .form-box {
    background: var(--c-bg-teal);
    border: 1px solid var(--c-blue-light);
    border-radius: 16px;
    padding: 2rem;
  }

  .submit-btn {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    background: var(--c-primary);
    color: white;
    transition: background 0.15s, transform 0.1s;
  }

  .submit-btn:hover {
    background: var(--c-primary-dark);
    transform: translateY(-1px);
  }

  @media (max-width: 843px) {
    .donate-inner { grid-template-columns: 1fr; gap: 2rem; }
    .roles-grid { grid-template-columns: 1fr; }
    .donate-box { position: static; }
    .contact-grid { gap: 2rem; }
  }

  @media (max-width: 768px) {
    .roles-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .donate-inner { grid-template-columns: 1fr; gap: 2rem; }
    .donate-box { position: static; }
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

