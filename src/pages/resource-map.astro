---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import ResourceMap from '../components/ResourceMap';
import '../styles/tailwind.css';

const serviceTypes = [
  {
    icon: '/images/icons/scale.png',
    name: 'Pro Bono Legal',
    color: 'var(--c-primary)',
    bg: 'var(--c-bg-teal)',
    border: 'var(--c-primary)',
    description: 'Free or reduced-cost legal representation and advice for survivors navigating the justice system. Pro bono attorneys can help with protective orders, Title IX complaints, civil suits, and more, ensuring every survivor has access to legal support regardless of financial situation.',
  },
  {
    icon: '🏥',
    name: 'SANE Program',
    color: 'var(--c-primary-dark)',
    bg: 'var(--c-bg-teal)',
    border: 'var(--c-primary-dark)',
    description: 'Sexual Assault Nurse Examiner (SANE) programs provide specialized, trauma-informed medical care after an assault. SANE nurses are trained to conduct forensic exams, preserve evidence, treat injuries, and connect survivors with follow-up support, all in a confidential, compassionate setting.',
  },
  {
    icon: '💜',
    name: 'Sexual Violence Services',
    color: 'var(--c-pink-dark)',
    bg: 'var(--c-bg-pink)',
    border: 'var(--c-pink-dark)',
    description: 'Comprehensive support services for survivors of sexual violence, including crisis intervention, counseling, advocacy, and case management. These organizations provide trauma-informed care and can walk alongside survivors at every stage of their healing journey.',
  },
  {
    icon: '🏠',
    name: 'Shelter / Safe House',
    color: 'var(--c-blue)',
    bg: 'var(--c-bg-blue)',
    border: 'var(--c-blue)',
    description: 'Emergency and transitional housing for survivors who need a safe place to go. Shelters provide confidential, secure accommodations along with on-site support services, case management, and resources to help survivors stabilize and plan for the future.',
  },
  {
    icon: '🧠',
    name: 'Counseling & Therapy',
    color: 'var(--c-yellow)',
    bg: 'var(--c-bg-yellow)',
    border: 'var(--c-yellow)',
    description: 'Trauma-informed mental health support from licensed therapists and counselors who specialize in sexual violence recovery. Services may include individual therapy, group therapy, EMDR, and other evidence-based approaches to help survivors process and heal.',
  },
  {
    icon: '📞',
    name: 'Crisis Hotlines',
    color: 'var(--c-pink)',
    bg: 'var(--c-bg-pink)',
    border: 'var(--c-pink)',
    description: 'Confidential, 24/7 crisis support lines staffed by trained advocates. Whether you need to talk, need help making a safety plan, or just aren\'t sure what to do next, hotline advocates are here to listen without judgment and connect you with local resources.',
  },
];
---

<Layout title="Resource Map" description="Find survivor support resources near you. The Summer Willis Foundation Resource Map.">

  <PageHeader
    title="Resource Map"
    subtitle="Find vetted survivor support services near you, searchable by location and type."
  />

  <section class="map-section">
    <div class="container">
      <div class="map-top-bar">
        <a href="/map" class="fullscreen-btn" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          Open Full Map
        </a>
      </div>
      <div class="map-wrapper">
        <ResourceMap client:visible />
      </div>
    </div>
  </section>

  <!-- Service Explanations -->
  <section class="section services-section">
    <img src="/images/icons/SWF - You Are Here.png" alt="" class="decor-icon decor-tl" aria-hidden="true" />
    <div class="container">
      <h2 class="section-title">Understanding the Services</h2>
      <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
      <p class="section-subtitle">Not sure what type of support you're looking for? Here's a breakdown of each service category on the map.</p>
      <div class="services-grid grid-3">
        {serviceTypes.map(service => (
          <div class="service-card" style={`background: ${service.bg}; border-top-color: ${service.border};`}>
            <div class="service-icon">{service.icon.startsWith('/') ? <img src={service.icon} alt="" class="service-icon-img" /> : service.icon}</div>
            <h3 style={`color: ${service.color};`}>{service.name}</h3>
            <p>{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Not sure where to start?"
    body="Reach out to us directly, and we can help connect you with the right resources."
    buttonText="Contact Us"
    buttonHref="/get-involved#contact"
  />

</Layout>

<style>
  .map-section {
    padding: 3rem 0 2rem;
  }

  .map-section .container {
    max-width: 1452px;
  }

  .map-top-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
  }

  .fullscreen-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #374151;
    text-decoration: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    transition: background 0.15s, border-color 0.15s;
  }

  .fullscreen-btn:hover {
    background: var(--c-bg-teal);
    border-color: var(--c-primary);
    color: var(--c-primary);
  }

  .map-wrapper {
    height: 946px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    border: 1px solid var(--c-blue-light);
    display: flex;
    flex-direction: column;
  }

  /* Fix Astro hydration wrapper breaking the h-full chain */
  .map-wrapper astro-island,
  .map-wrapper astro-island > div {
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Services */
  .services-section {
    position: relative;
    overflow: hidden;
    background: #f9fafb;
  }

  .services-grid {
    gap: 1.5rem;
  }

  .service-card {
    border-radius: 12px;
    padding: 1.75rem;
    border-top: 4px solid transparent;
    transition: box-shadow 0.2s;
  }

  .service-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .service-icon-img { width: 2rem; height: 2rem; object-fit: contain; display: block; }

  .service-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .map-wrapper { height: min(700px, 78vh); }
  }

  @media (max-width: 843px) {
    .map-wrapper { height: min(680px, 80vh); }
    .map-section { padding: 1.5rem 0 1.5rem; }
  }

  @media (max-width: 768px) {
    .map-wrapper { height: min(680px, 80vh); }
    .services-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .map-wrapper { height: min(600px, 82vh); }
    .map-section { padding: 1rem 0 1rem; }
    .map-section .container { padding: 0 0.75rem; }
  }

  @media (min-width: 640px) and (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
