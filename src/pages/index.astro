---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
---

<Layout title="Home" description="Summer Willis Foundation — Building stronger communities through food support, housing assistance, and family services.">

  <HeroSlider />

  <!-- Hero -->
  <section class="hero">
    <img src="/images/icons/SWF - Sun.png" alt="" class="hero-sun hero-sun-1" aria-hidden="true" />
    <img src="/images/icons/SWF - Sun.png" alt="" class="hero-sun hero-sun-2" aria-hidden="true" />
    <img src="/images/icons/SWF - Sun.png" alt="" class="hero-sun hero-sun-3" aria-hidden="true" />
    <div class="container">
      <div class="hero-content">
        <span class="hero-badge">501(c)(3) Non-Profit</span>
        <h1>Every story holds power, and every voice can spark movement.</h1>
        <p>Summer Willis Foundation exists to reframe the narrative around sexual violence, empower survivors to reclaim their stories, and create lasting systemic change that prevents future harm.</p>
        <div class="hero-actions">
          <a href="/get-involved#donate" class="btn-donate">Support Our Work</a>
          <a href="/campaigns" class="btn-outline-white">Our Campaigns</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat stat-teal">
          <div class="stat-number">2,800+</div>
          <div class="stat-label">Survivors Supported</div>
        </div>
        <div class="stat stat-yellow">
          <div class="stat-number">150+</div>
          <div class="stat-label">Community Events</div>
        </div>
        <div class="stat stat-pink">
          <div class="stat-number">40+</div>
          <div class="stat-label">Advocacy Campaigns</div>
        </div>
        <div class="stat stat-blue">
          <div class="stat-number">12 yrs</div>
          <div class="stat-label">Serving Our Community</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder Story -->
  <section class="section story-section">
    <img src="/images/icons/SWF - You Are Here.png" alt="" class="decor-icon decor-bl" aria-hidden="true" />
    <div class="container story-grid">
      <div class="story-image">
        <img src="/images/photos/summer1.jpg" alt="Summer Willis running — strength through strides" />
      </div>
      <div class="story-content">
        <h2>All About Our Story</h2>
        <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
        <p>Our founder, Summer Willis, is a survivor of sexual violence. In the wake of her assault, she experienced firsthand the systemic failures, silence, and shame that often define the survivor experience. She began running as a bold act of reclamation. This personal challenge grew into <strong>Project 29</strong> — a commitment to run 29 marathons as a testament to her own resilience. She met survivors around the world, each with different lives yet she observed the same pattern. She realized sexual violence thrives on shame, silence, and laws that haven't kept up with reality. Eventually, Project 29 grew into the Summer Willis Foundation.</p>
        <p class="story-extended">Running was only the start. Summer found her true, renewed strength not just in the miles, but in community — in the power of telling her story without shame, and in a fierce new purpose: creating tangible change so that what happened to her wouldn't happen to others. She realized she had a choice: accept the narrative of "victim," or rewrite it. She chose to rewrite it.</p>
        <blockquote class="founder-quote">
          <p>"I realized I didn't have to accept the story written for me. I could write my own."</p>
          <cite>— Summer Willis, Founder</cite>
        </blockquote>
        <a href="/about" class="btn btn-primary">Read More</a>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section mission-section">
    <div class="container">
      <h2 class="section-title" style="text-align:center;">The SWF Approach</h2>
      <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" style="margin: 0.4rem auto 2.5rem;" aria-hidden="true" />
      <div class="approach-grid">
        <div class="approach-card approach-mission">
          <div class="approach-label">Mission</div>
          <p>Through our commitment to advocacy, community, and resource provision, the Summer Willis Foundation exists to reframe the narrative around sexual violence, empower survivors to reclaim their stories, and create lasting systemic change that prevents future harm.</p>
        </div>
        <div class="approach-card approach-vision">
          <div class="approach-label">Vision</div>
          <p>Through our commitment to advocacy, community, and resource provision, the Summer Willis Foundation exists to reframe the narrative around sexual violence, empower survivors to reclaim their stories, and create lasting systemic change that prevents future harm.</p>
        </div>

      </div>
      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/about" class="btn btn-primary">Learn Our Story</a>
      </div>
    </div>
  </section>

  <!-- Programs Preview -->
  <section class="section programs-section">
    <img src="/images/icons/SWF - Sun.png" alt="" class="decor-icon decor-tl" aria-hidden="true" />
    <img src="/images/icons/SWF - Sun.png" alt="" class="decor-icon decor-br" aria-hidden="true" />
    <div class="container">
      <h2 class="section-title">Our Campaigns</h2>
      <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
      <p class="section-subtitle">Bold, community-driven initiatives creating change at every level — individual, community, and systemic.</p>
      <div class="programs-grid">
        <div class="program-card card-teal">
          <div class="program-icon">👟</div>
          <h3>The Denim Runs</h3>
          <p>Community running events where participants wear denim in solidarity with survivors — reclaiming bodies, stories, and strength.</p>
          <a href="/campaigns#denim-runs" class="card-link">Learn more →</a>
        </div>
        <div class="program-card card-blue">
          <div class="program-icon">⚖️</div>
          <h3>Legislation</h3>
          <p>Bipartisan policy advocacy fighting for stronger survivor protections, fairer legal processes, and laws that keep up with reality.</p>
          <a href="/campaigns#legislation" class="card-link">Learn more →</a>
        </div>
        <div class="program-card card-yellow">
          <div class="program-icon">🗺️</div>
          <h3>The Resource Map</h3>
          <p>A survivor-centered directory of vetted crisis lines, counseling, legal advocates, and support services — searchable by location.</p>
          <a href="/campaigns#resource-map" class="card-link">Learn more →</a>
        </div>
      </div>
      <div style="text-align:center; margin-top: 1.5rem;">
        <a href="/campaigns#letter-film" class="card-link" style="font-size:1rem;">🎬 Also: "A Letter to My Younger Self" Film →</a>
      </div>
    </div>
  </section>

  <!-- Voices of the Movement -->
  <section class="section voices-section">
    <div class="container">
      <div class="voices-header">
        <div>
          <h2 class="section-title">Voices of the Movement</h2>
          <img src="/images/icons/SWF - Underline.png" alt="" class="section-underline" aria-hidden="true" />
        </div>
      </div>
      <div class="voices-carousel" id="voices-carousel">
        <div class="voices-track">
          <div class="voice-card quote-teal">
            <span class="voice-quotemark" aria-hidden="true">&ldquo;</span>
            <p class="voice-quote">Through Summer's perseverance, I discovered the inner strength to keep healing and to run my own marathon.</p>
            <div class="voice-author">
              <div class="voice-avatar">👟</div>
              <div>
                <div class="voice-name">Tristan E.</div>
                <div class="voice-role">Denim Run Ambassador</div>
              </div>
            </div>
          </div>
          <div class="voice-card quote-yellow">
            <span class="voice-quotemark" aria-hidden="true">&ldquo;</span>
            <p class="voice-quote">As a parent of a survivor, SWF has helped me walk alongside my daughter in her journey. It has also allowed me to use my voice and experience to stand with other parents.</p>
            <div class="voice-author">
              <div class="voice-avatar">💛</div>
              <div>
                <div class="voice-name">Paulina P.</div>
                <div class="voice-role">Advisory Board Member</div>
              </div>
            </div>
          </div>
          <div class="voice-card quote-pink">
            <span class="voice-quotemark" aria-hidden="true">&ldquo;</span>
            <p class="voice-quote">Walking in the April 2025 Denim March filled me with a sense of hope and inspiration. It brought together a community so fiercely dedicated to making this world a better place, and I am immensely proud to stand together in support.</p>
            <div class="voice-author">
              <div class="voice-avatar">🤝</div>
              <div>
                <div class="voice-name">Logan S.</div>
                <div class="voice-role">SWF Volunteer</div>
              </div>
            </div>
          </div>
          <div class="voice-card quote-blue">
            <span class="voice-quotemark" aria-hidden="true">&ldquo;</span>
            <p class="voice-quote">Being part of this foundation has reminded me that real change starts with one person choosing to speak and others choosing to listen.</p>
            <div class="voice-author">
              <div class="voice-avatar">🌟</div>
              <div>
                <div class="voice-name">Heila S.</div>
                <div class="voice-role">SWF Team</div>
              </div>
            </div>
          </div>

          <div class="voice-card quote-pink">
            <span class="voice-quotemark" aria-hidden="true">&ldquo;</span>
            <p class="voice-quote">When a woman finds her authentic voice, she finds her power — and everything changes. Summer's story is proof of that.</p>
            <div class="voice-author">
              <div class="voice-avatar">✨</div>
              <div>
                <div class="voice-name">Gabriella Taylor, M.A.</div>
                <div class="voice-role">Advocate</div>
              </div>
            </div>
          </div>
        </div>

        <div class="voices-controls">
          <button class="voices-arrow" id="voices-prev" aria-label="Previous">&#8592;</button>
          <button class="voices-arrow" id="voices-next" aria-label="Next">&#8594;</button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->

  <section class="cta-section">
    <img src="/images/icons/SWF - Sun.png" alt="" class="cta-sun" aria-hidden="true" />
    <div class="container cta-inner">
      <div>
        <h2>Stand With Survivors</h2>
        <p>Your time, voice, and support help us create the change that survivors deserve.</p>
      </div>
      <div class="cta-actions">
        <a href="/get-involved#volunteer" class="btn btn-white">Get Involved</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const carousel = document.getElementById('voices-carousel');
  if (carousel) {
    const track = carousel.querySelector('.voices-track') as HTMLElement;
    const cards = carousel.querySelectorAll('.voice-card');
    const dotsContainer = document.getElementById('voices-dots')!;
    const prevBtn = document.getElementById('voices-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('voices-next') as HTMLButtonElement;

    // Determine how many cards are visible based on viewport
    function getVisible(): number {
      if (window.innerWidth <= 480) return 1;
      if (window.innerWidth <= 768) return 2;
      return 3;
    }

    let current = 0;
    const total = cards.length;

    // Build dots — one per possible starting position
    function buildDots() {
      dotsContainer.innerHTML = '';
      const visible = getVisible();
      const count = Math.max(1, total - visible + 1);
      for (let i = 0; i < count; i++) {
        const dot = document.createElement('button');
        dot.className = 'voices-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function goTo(index: number) {
      const visible = getVisible();
      const maxIndex = Math.max(0, total - visible);
      current = Math.max(0, Math.min(index, maxIndex));

      // Shift track by one card width + gap (gap = 1.5rem = 24px)
      const cardWidth = (cards[0] as HTMLElement).offsetWidth;
      track.style.transform = `translateX(calc(-${current} * (${cardWidth}px + 1.5rem)))`;

      // Update dots
      dotsContainer.querySelectorAll('.voices-dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });

      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= maxIndex;
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    // Rebuild on resize
    window.addEventListener('resize', () => {
      buildDots();
      goTo(0);
    });

    buildDots();
    goTo(0);
  }
</script>

<style>
  /* Shared icon styles */
  .section-underline {
    height: 28px;
    width: auto;
    display: block;
    margin: 0.4rem 0 1.25rem;
    opacity: 0.85;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
    color: white;
    padding: 6rem 0;
    text-align: center;
  }


  .hero-sun {
    position: absolute;
    height: auto;
    pointer-events: none;
  }
  /* Closest / brightest */
  .hero-sun-1 {
    top: -30px;
    right: -30px;
    width: 280px;
    opacity: 0.35;
  }
  /* Middle */
  .hero-sun-2 {
    top: -60px;
    right: -60px;
    width: 400px;
    opacity: 0.20;
  }
  /* Furthest / faintest */
  .hero-sun-3 {
    top: -90px;
    right: -90px;
    width: 520px;
    opacity: 0.08;
  }

  .hero-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    background: var(--c-yellow);
    color: #111827;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .hero p {
    font-size: 1.15rem;
    opacity: 0.9;
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-donate {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    background: var(--c-yellow);
    color: #111827;
    transition: background 0.15s, transform 0.1s;
  }

  .btn-donate:hover {
    background: var(--c-yellow-light);
    transform: translateY(-1px);
  }

  .btn-outline-white {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,0.7);
    color: white;
    transition: background 0.15s;
  }

  .btn-outline-white:hover { background: rgba(255,255,255,0.15); }

  /* Decorative icons */
  .decor-icon {
    position: absolute;
    width: 180px;
    height: auto;
    opacity: 0.18;
    pointer-events: none;
  }
  .decor-sm { width: 90px; }
  .decor-br { bottom: 16px; right: 16px; }
  .decor-tl { top: 16px; left: 16px; }
  .decor-tr { top: 16px; right: 16px; }
  .decor-bl { bottom: 16px; left: 16px; }

  /* Stats */
  .stats-section {
    position: relative;
    overflow: hidden;
    background: var(--c-bg-teal);
    padding: 3rem 0;
    border-bottom: 1px solid var(--c-blue-light);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }

  .stat {
    border-radius: 12px;
    padding: 1.5rem 1rem;
  }

  .stat-teal { background: var(--c-bg-teal); }
  .stat-yellow { background: var(--c-bg-yellow); }
  .stat-pink { background: var(--c-bg-pink); }
  .stat-blue { background: var(--c-bg-blue); }

  .stat-number {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--c-primary);
  }

  .stat-yellow .stat-number { color: var(--c-primary-dark); }
  .stat-pink .stat-number { color: var(--c-pink-dark); }
  .stat-blue .stat-number { color: var(--c-blue); }

  .stat-label {
    font-size: 0.9rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  /* Founder Story */
  .story-section { position: relative; overflow: hidden; background: #f9fafb; }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .story-image img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .story-content h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.25rem;
  }

  .story-content p {
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .story-extended { color: #374151; }

  .founder-quote {
    border-left: 4px solid var(--c-yellow);
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    background: var(--c-bg-yellow);
    border-radius: 0 8px 8px 0;
  }

  .founder-quote p {
    font-size: 1.1rem;
    font-style: italic;
    color: #111827;
    margin: 0 0 0.35rem;
  }

  .founder-quote cite {
    font-size: 0.875rem;
    color: #6b7280;
    font-style: normal;
    font-weight: 600;
  }

  /* Mission & Vision */
  .approach-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .approach-card {
    border-radius: 16px;
    padding: 2rem;
    border-top: 4px solid transparent;
  }

  .approach-mission {
    background: var(--c-bg-teal);
    border-top-color: var(--c-primary);
  }

  .approach-vision {
    background: var(--c-bg-pink);
    border-top-color: var(--c-pink-dark);
  }

  .approach-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-primary);
    margin-bottom: 0.75rem;
  }

  .approach-vision .approach-label { color: var(--c-pink-dark); }

  .approach-card p {
    color: #374151;
    line-height: 1.75;
    margin: 0;
    font-size: 1rem;
  }

  /* Programs */
  .programs-section { position: relative; overflow: hidden; background: #f9fafb; }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .program-card {
    border-radius: 12px;
    padding: 1.75rem;
    border: 1px solid transparent;
    transition: box-shadow 0.2s;
  }

  .program-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

  .card-teal {
    background: var(--c-bg-teal);
    border-color: var(--c-primary);
    border-left-width: 4px;
  }

  .card-blue {
    background: var(--c-bg-blue);
    border-color: var(--c-blue);
    border-left-width: 4px;
  }

  .card-yellow {
    background: var(--c-bg-yellow);
    border-color: var(--c-yellow);
    border-left-width: 4px;
  }

  .program-icon { font-size: 2rem; margin-bottom: 0.75rem; }

  .program-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .program-card p {
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .card-link {
    color: var(--c-primary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Voices */
  .voices-section { background: white; }

  .voices-header {
    margin-bottom: 2rem;
  }

  .voices-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary);
    margin: 0 0 0.3rem;
  }

  .voices-carousel {
    position: relative;
    overflow: hidden;
    padding: 1rem;
    margin: -1rem;
  }

  .voices-track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .voice-card {
    border-radius: 16px;
    padding: 1.75rem;
    aspect-ratio: 1 / 1;
    flex: 0 0 calc((100% - 3rem) / 3);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .voices-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .voices-arrow {
    background: none;
    border: 1px solid var(--c-blue-light);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    font-size: 1rem;
    cursor: pointer;
    color: var(--c-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }

  .voices-arrow:hover {
    background: var(--c-bg-teal);
    border-color: var(--c-primary);
  }

  .voices-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .voices-dots {
    display: flex;
    gap: 0.5rem;
  }

  .voices-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid #d1d5db;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s;
  }

  :global(.voices-dot.active) {
    border-color: var(--c-primary);
    background: transparent;
  }

  /* White card base */
  .voice-card {
    background: white;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  }

  .quote-teal  .voice-quotemark { color: var(--c-primary); }
  .quote-yellow .voice-quotemark { color: var(--c-yellow); }
  .quote-pink  .voice-quotemark { color: var(--c-pink-dark); }
  .quote-blue  .voice-quotemark { color: var(--c-blue); }

  .voice-quotemark {
    display: block;
    font-family: Georgia, serif;
    font-size: 4.5rem;
    line-height: 0.8;
    margin-bottom: 0.25rem;
    user-select: none;
    flex-shrink: 0;
  }

  .voice-quote {
    font-size: 0.9rem;
    color: #374151;
    line-height: 1.65;
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  .voice-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.75rem;
    margin-top: 0.75rem;
    border-top: 1px solid #f3f4f6;
    flex-shrink: 0;
  }

  .voice-avatar {
    font-size: 1.5rem;
