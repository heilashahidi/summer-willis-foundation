---
import Layout from '../../layouts/Layout.astro';

const title = 'The Denim Run Los Angeles'
const date = 'April 12, 2026'
const location = 'Los Angeles, CA'
const tag = 'The Denim Runs'
const folder = 'Denim Run April 2026'
const description = 'Our first-ever Denim Run brought together survivors, advocates, and community members in Los Angeles for a powerful morning of movement and solidarity. Participants wore denim as a symbol of defiance against victim-blaming, every stride a statement that we believe survivors. The energy, the community, and the stories shared made this a day none of us will forget.'

const photos = [
  '0001_elizabethmessina_DENIM_RUNS.jpg',
  '0002_elizabethmessina_DENIM_RUNS.jpg',
  '0004_elizabethmessina_DENIM_RUNS.jpg',
  '0007_elizabethmessina_DENIM_RUNS.jpg',
  '0011_elizabethmessina_DENIM_RUNS.jpg',
  '0014_elizabethmessina_DENIM_RUNS.jpg',
  '0016_elizabethmessina_DENIM_RUNS.jpg',
  '0017_elizabethmessina_DENIM_RUNS.jpg',
  '0018_elizabethmessina_DENIM_RUNS.jpg',
  '0027_elizabethmessina_DENIM_RUNS.jpg',
  '0039_elizabethmessina_DENIM_RUNS.jpg',
  '0081_elizabethmessina_DENIM_RUNS.jpg',
  '0084_elizabethmessina_DENIM_RUNS.jpg',
  '0132_elizabethmessina_DENIM_RUNS.jpg',
  '0134_elizabethmessina_DENIM_RUNS.jpg',
]
---

<Layout title={`${title} (${date})`} description={description}>

  <section class="event-hero">
    <div class="container">
      <a href="/events" class="back-link">← All Events</a>
      <div class="event-header">
        <span class="event-tag">{tag}</span>
        <h1>{title}</h1>
        <div class="event-details">
          <span>📅 {date}</span>
          <span>📍 {location}</span>
        </div>
        <p class="event-description">{description}</p>
      </div>
    </div>
  </section>

  <section class="photo-section">
    <div class="container">
      <div class="photo-grid">
        {photos.map((photo, i) => (
          <button
            class="photo-item"
            data-src={`/images/${folder}/${photo}`}
            aria-label={`View photo ${i + 1}`}
          >
            <img
              src={`/images/${folder}/${photo}`}
              alt={`${title} (${date}) photo ${i + 1}`}
              loading={i < 6 ? 'eager' : 'lazy'}
              decoding="async"
              class="photo-img"
            />
          </button>
        ))}
      </div>
      <div class="full-gallery-cta">
        <p class="full-gallery-note">Want to see more? Browse the complete event gallery captured by photographer Elizabeth Messina.</p>
        <a
          href="https://elizabethmessina.pixieset.com/thedenimruns/"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >📷 View Full Gallery on Pixieset →</a>
      </div>
    </div>
  </section>

  {/* Lightbox */}
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">✕</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous">&#8592;</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="Next">&#8594;</button>
    <div class="lightbox-img-wrap">
      <img id="lightbox-img" src="" alt="" />
    </div>
    <p id="lightbox-counter" class="lightbox-counter"></p>
  </div>

</Layout>

<script>
  document.querySelectorAll<HTMLImageElement>('.photo-img').forEach(img => {
    if (img.complete) {
      img.classList.add('loaded')
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'))
    }
  })

  const lightbox = document.getElementById('lightbox')!
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement
  const lightboxCounter = document.getElementById('lightbox-counter')!
  const closeBtn = document.getElementById('lightbox-close')!
  const prevBtn = document.getElementById('lightbox-prev')!
  const nextBtn = document.getElementById('lightbox-next')!

  const buttons = Array.from(document.querySelectorAll('.photo-item')) as HTMLButtonElement[]
  const srcs = buttons.map(b => b.dataset.src!)
  let current = 0

  function showPhoto() {
    lightboxImg.src = srcs[current]
    lightboxCounter.textContent = `${current + 1} / ${srcs.length}`
    prevBtn.style.display = current === 0 ? 'none' : 'flex'
    nextBtn.style.display = current === srcs.length - 1 ? 'none' : 'flex'
  }

  buttons.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      current = i
      showPhoto()
      lightbox.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    })
  })

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  closeBtn.addEventListener('click', closeLightbox)
  prevBtn.addEventListener('click', () => { current--; showPhoto() })
  nextBtn.addEventListener('click', () => { current++; showPhoto() })
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox() })
  document.addEventListener('keydown', (e) => {
    if (lightbox.getAttribute('aria-hidden') === 'true') return
    if (e.key === 'Escape') closeLightbox()
    if (e.key === 'ArrowLeft' && current > 0) { current--; showPhoto() }
    if (e.key === 'ArrowRight' && current < srcs.length - 1) { current++; showPhoto() }
  })
</script>

<style>
  .event-hero {
    background: var(--c-bg-teal);
    padding: var(--section-padding) 0 5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--c-primary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    padding-top: 1rem;
  }

  .back-link:hover { text-decoration: underline; }

  .event-header { max-width: 720px; }

  .event-tag {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1.5px solid var(--c-primary);
    color: var(--c-primary);
    border-radius: 20px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 0.75rem;
  }

  .event-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #111827;
  }

  .event-details {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: #6b7280;
    font-weight: 600;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .event-description {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.75;
    margin: 0 0 3rem;
  }

  .photo-section {
    padding: 6rem 0 var(--section-padding);
    background: white;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .full-gallery-cta {
    margin-top: 3rem;
    text-align: center;
    padding: 2rem 1.5rem;
    background: var(--c-bg-teal);
    border-radius: 16px;
  }

  .full-gallery-note {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0 auto 1.25rem;
    max-width: 540px;
  }

  .photo-item {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 12px;
    cursor: pointer;
    border: none;
    padding: 0;
    background: #e5e7eb;
    display: block;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.3s ease;
  }

  .photo-img.loaded { opacity: 1; }
  .photo-item:hover .photo-img { transform: scale(1.04); opacity: 0.92; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[aria-hidden="true"] { display: none; }

  .lightbox-img-wrap {
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img-wrap img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
    opacity: 0.7;
    line-height: 1;
  }

  .lightbox-close:hover { opacity: 1; }

  .lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .lightbox-prev { left: 1.25rem; }
  .lightbox-next { right: 1.25rem; }
  .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255,255,255,0.3); }

  .lightbox-counter {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .photo-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .event-header h1 { font-size: 1.5rem; }
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
  }
</style>
