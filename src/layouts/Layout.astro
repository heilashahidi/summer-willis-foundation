---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import QuickExit from '../components/QuickExit.astro';
import { SEO } from 'astro-seo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Summer Willis Foundation',
  description = 'Summer Willis Foundation empowers survivors of sexual violence through advocacy, community, and resources, helping survivors reclaim their stories and create lasting systemic change.',
  image = '/images/photos/summer1.jpg',
} = Astro.props;

const fullTitle = title === 'Summer Willis Foundation'
  ? title
  : `${title} | Summer Willis Foundation`;

const siteUrl = 'https://www.summerwillisfoundation.org';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteImage = new URL(image, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NonprofitOrganization',
  name: 'Summer Willis Foundation',
  url: siteUrl,
  logo: `${siteUrl}/images/icons/favicon-32x32.png`,
  description: 'Summer Willis Foundation exists to reframe the narrative around sexual violence, empower survivors to reclaim their stories, and create lasting systemic change.',
  foundingDate: '2013',
  founder: {
    '@type': 'Person',
    name: 'Summer Willis',
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=100093688899030',
    'https://www.linkedin.com/company/summer-willis-foundation/',
    'https://www.instagram.com/summerwillisfoundation/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: `${siteUrl}/get-involved#contact`,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/icons/favicon-32x32.png" sizes="32x32" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      // Suppress small JS-triggered scroll adjustments from GiveButter widget init
      // Anchor navigation uses CSS scroll-behavior so it's unaffected
      const _scrollTo = window.scrollTo.bind(window);
      window.scrollTo = function(x, y) {
        const opts = (typeof x === 'object' && x !== null) ? x : { left: x, top: y };
        const targetTop = opts.top !== undefined ? opts.top : window.scrollY;
        if (Math.abs(targetTop - window.scrollY) > window.innerHeight * 0.3) {
          _scrollTo({ ...opts, behavior: 'smooth' });
        }
      };
      Element.prototype.scrollIntoView = function() {};
    </script>
    <script is:inline async src="https://widgets.givebutter.com/latest.umd.cjs?acct=eoFddejDzFLCJ710&p=other"></script>
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'website',
          image: absoluteImage,
        },
        optional: {
          description: description,
          siteName: 'Summer Willis Foundation',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: fullTitle,
        description: description,
        image: absoluteImage,
      }}
    />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
    <QuickExit />
    <givebutter-widget id="jwPoeL"></givebutter-widget>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'TAYBirdie';
    src: url('/fonts/TAYBirdieRegular.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --c-primary:      #00909d;
    --c-primary-dark: #006b7a;
    --c-yellow:       #ffc60b;
    --c-yellow-light: #ffe896;
    --c-pink:         #f37f8e;
    --c-pink-dark:    #ef3f6b;
    --c-blue:         #6e98b9;
    --c-blue-light:   #bad0ec;
    --c-bg-teal:      #eff8fa;
    --c-bg-yellow:    #fff7eb;
    --c-bg-pink:      #fef2f1;
    --c-bg-blue:      #eef5fc;
    --c-text-secondary: #6b7280;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Nunito', system-ui, sans-serif;
    color: #111827;
    background: #ffffff;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'TAYBirdie', system-ui, sans-serif;
  }

  img { max-width: 100%; }

  .sun-bl {
    position: absolute;
    bottom: -30px;
    left: -30px;
    width: 200px;
    height: auto;
    opacity: 0.1;
    pointer-events: none;
  }

  /* Shared utility classes */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem;
  }

  .section-subtitle {
    font-size: 1.15rem;
    color: #6b7280;
    margin: 0 0 2.5rem;
    line-height: 1.7;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
    cursor: pointer;
    border: none;
  }

  .btn:hover { transform: translateY(-1px); }

  .btn-primary {
    background: var(--c-primary);
    color: white;
  }

  .btn-primary:hover { background: var(--c-primary-dark); }

  .btn-outline {
    background: transparent;
    color: var(--c-primary);
    border: 2px solid var(--c-primary);
  }

  .btn-outline:hover { background: var(--c-bg-teal); }

  .btn-white {
    background: white;
    color: var(--c-primary);
  }

  .btn-white:hover { background: #f9fafb; }

  /* Page header — shared across all inner pages */
  .page-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--c-primary-dark), var(--c-primary));
    color: white;
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .page-header p { font-size: 1.1rem; opacity: 0.9; margin: 0; }

  .header-sun {
    position: absolute;
    top: -30px;
    right: -30px;
    width: 220px;
    height: auto;
    opacity: 0.12;
    pointer-events: none;
  }

  /* Section underline decoration */
  .section-underline {
    height: 28px;
    width: auto;
    display: block;
    margin: 0.4rem 0 1.25rem;
    opacity: 0.85;
  }

  /* 3-column responsive grid utility */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  /* Shared form styles */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.6rem 0.85rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #111827;
    background: white;
    transition: border-color 0.15s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(0, 144, 157, 0.12);
  }

  /* Decorative corner icons — shared across pages */
  .decor-icon {
    position: absolute;
    width: 160px;
    height: auto;
    opacity: 0.18;
    pointer-events: none;
  }
  .decor-sm  { width: 90px; }
  .decor-tl  { top: 16px;    left: 16px;  }
  .decor-tr  { top: 16px;    right: 16px; }
  .decor-bl  { bottom: 16px; left: 16px;  }
  .decor-br  { bottom: 16px; right: 16px; }

  /* Scroll reveal animations */
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  const targets = document.querySelectorAll(
    '.section, .stat-card, .value-card, .tenet-card, .advisory-card, ' +
    '.founder-card, .role-card, .campaign-highlight, .upcoming-event, ' +
    '.campaign-grid, .donate-inner, .hero-content, .story-grid'
  );

  targets.forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>
