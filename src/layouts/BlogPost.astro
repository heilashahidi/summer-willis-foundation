---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  categoryColor: string;
  emoji: string;
  image?: string;
}

const { title, description, date, category, categoryColor, emoji, image } = Astro.props;
---

<Layout title={title} description={description} image={image}>
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="article:published_time" content={new Date(date).toISOString()} />
  <meta slot="head" property="article:section" content={category} />

  <section class="post-header">
    <div class="container">
      <div class="post-meta">
        <span class="category" style={`background: ${categoryColor};`}>{category}</span>
        <span class="date">{date}</span>
      </div>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
    </div>
  </section>

  <section class="section">
    <div class="container post-layout">
      <article class="post-body">
        <slot />
      </article>

      <aside class="post-sidebar">
        <div class="sidebar-card">
          <h3>About SWF</h3>
          <p>Summer Willis Foundation supports survivors of sexual violence through advocacy, community, and resources.</p>
          <a href="/about" class="btn btn-primary" style="width:100%;text-align:center;display:block;">Learn More</a>
        </div>
        <div class="sidebar-card">
          <h3>Find Resources</h3>
          <p>Search our map of vetted survivor support services near you.</p>
          <a href="/resource-map" class="btn btn-outline" style="width:100%;text-align:center;display:block;">Resource Map</a>
        </div>
        <div class="sidebar-card">
          <h3>Get Involved</h3>
          <p>Volunteer, donate, or spread the word. Every action creates change.</p>
          <a href="/get-involved" class="btn btn-outline" style="width:100%;text-align:center;display:block;">Take Action</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="back-section">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </div>
  </section>

</Layout>

<style>
  .post-header {
    background: linear-gradient(135deg, var(--c-primary-dark), var(--c-primary));
    color: white;
    padding: 4rem 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .category {
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .date { font-size: 0.85rem; opacity: 0.8; }

  .post-header h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    margin: 0 0 1rem;
    line-height: 1.3;
    max-width: 760px;
  }

  .post-description {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0;
    max-width: 680px;
    line-height: 1.6;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  .post-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #374151;
  }

  .post-body h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 2rem 0 0.75rem;
  }

  .post-body h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #111827;
    margin: 1.5rem 0 0.5rem;
  }

  .post-body p { margin: 0 0 1.25rem; }

  .post-body ul, .post-body ol {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }

  .post-body li { margin-bottom: 0.5rem; }

  .post-body strong { color: #111827; }

  .post-body blockquote {
    border-left: 4px solid var(--c-primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--c-bg-teal);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #4b5563;
  }

  .post-body a {
    color: var(--c-primary);
    text-decoration: underline;
  }

  .sidebar-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .sidebar-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #111827;
  }

  .sidebar-card p {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.5;
    margin: 0 0 1rem;
  }

  .back-section {
    padding: 1.5rem 0 3rem;
    border-top: 1px solid #e5e7eb;
  }

  .back-link {
    color: var(--c-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { display: none; }
  }
</style>
